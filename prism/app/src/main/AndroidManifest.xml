<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Storage access for local video files + 3D models -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Full file access for non-media files (.glb, .gltf, .funscript, .hsp) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- XR permissions -->
    <uses-permission android:name="android.permission.HAND_TRACKING" />

    <!-- XR features -->
    <uses-feature android:name="android.software.xr.api.spatial" android:required="true" />
    <uses-feature android:name="android.hardware.xr.input.hand_tracking" android:required="false" />

    <application
        android:label="ChloeVR"
        android:icon="@android:drawable/ic_media_play"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar"
        android:requestLegacyExternalStorage="true">

        <!-- OpenXR native runtime -->
        <uses-native-library android:name="libopenxr.google.so" android:required="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">

            <!-- Launch directly into Full Space for immersive video -->
            <property
                android:name="android.window.PROPERTY_XR_ACTIVITY_START_MODE"
                android:value="XR_ACTIVITY_START_MODE_FULL_SPACE_MANAGED" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
